<div class="em-forecast-panel"><style>
.em-forecast-panel{border:1px solid #e0e0e0;border-radius:8px;padding:16px;overflow:hidden;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif}
.em-forecast-panel h2{font-size:1.1rem;margin:0 0 12px 0}
.em-forecast-panel table{width:100%;border-collapse:collapse;font-size:13px;table-layout:fixed}
.em-forecast-panel thead th{background:#667ee2;color:#fff;padding:8px 10px;text-align:left;font-weight:600;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
.em-forecast-panel tbody td{padding:6px 10px;border-bottom:1px solid #eee;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
.em-forecast-panel tbody tr:nth-child(even){background:#f5f5f5}
.em-forecast-panel .progress-wrap{display:flex;align-items:center;gap:6px}
.em-forecast-panel .progress-wrap progress{width:70px;height:7px;accent-color:#667ee2}
.em-forecast-panel .progress-label{color:#888;font-size:11px;white-space:nowrap}
</style>
<h2>{{.Title}}</h2>
<table>
  <colgroup><col style="width:14%"><col style="width:30%"><col style="width:20%"><col style="width:12%"><col style="width:12%"><col style="width:12%"></colgroup>
  <thead><tr><th>Epic</th><th>Summary</th><th>Progress</th><th>50%</th><th>85%</th><th>95%</th></tr></thead>
  <tbody>{{range .Rows}}<tr>
    <td>{{.EpicKey}}</td>
    <td>{{.Summary}}</td>
    <td><div class="progress-wrap"><progress value="{{.ProgressVal}}" max="{{.ProgressMax}}"></progress><span class="progress-label">{{.ProgressLabel}}</span></div></td>
    <td>{{.Forecast50}}</td>
    <td>{{.Forecast85}}</td>
    <td>{{.Forecast95}}</td>
  </tr>{{end}}</tbody>
</table>
</div>
