<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{.Title}}</title>
<style>
  body { margin: 0; padding: 20px; background: #fff; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  .container { max-width: 900px; margin: 0 auto; }
  h1 { font-size: 1.5rem; margin-bottom: 1rem; }
  table { width: 100%; border-collapse: collapse; font-size: 14px; }
  thead th { background: #667ee2; color: #fff; padding: 10px 12px; text-align: left; font-weight: 600; }
  tbody td { padding: 8px 12px; border-bottom: 1px solid #eee; vertical-align: middle; }
  tbody tr:nth-child(even) { background: #f5f5f5; }
  .progress-wrap { display: flex; align-items: center; gap: 8px; }
  .progress-wrap progress { width: 80px; height: 8px; accent-color: #667ee2; }
  .progress-label { color: #666; font-size: 12px; white-space: nowrap; }
  .key { white-space: nowrap; }
</style>
</head>
<body>
<div class="container">
  <h1>{{.Title}}</h1>
  <table>
    <thead>
      <tr><th class="key">Epic</th><th>Summary</th><th>Progress</th><th>50%</th><th>85%</th><th>95%</th></tr>
    </thead>
    <tbody>
      {{range .Rows}}<tr>
        <td class="key">{{.EpicKey}}</td>
        <td>{{.Summary}}</td>
        <td>
          <div class="progress-wrap">
            <progress value="{{.ProgressVal}}" max="{{.ProgressMax}}"></progress>
            <span class="progress-label">{{.ProgressLabel}}</span>
          </div>
        </td>
        <td>{{.Forecast50}}</td>
        <td>{{.Forecast85}}</td>
        <td>{{.Forecast95}}</td>
      </tr>{{end}}
    </tbody>
  </table>
</div>
</body>
</html>
