<style>
.slo-grid{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:20px}
.slo-widget{width:221px;height:105px;background:#f9f9f9;border-radius:10px;padding:10px 12px;display:flex;flex-direction:column;box-shadow:0 1px 3px rgba(0,0,0,.07)}
.slo-widget.widget-alerted{border-top:3px solid #e53935}
.slo-widget.widget-ok{border-top:3px solid #43a047}
.slo-widget-service{font-size:.72rem;font-weight:600;color:#666;margin-bottom:8px}
.slo-widget-name{font-size:.68rem;font-weight:600;color:#555;line-height:1.3;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}
.slo-widget-def{font-size:.6rem;color:#888;line-height:1.3;margin-top:2px}
.slo-widget-count{display:flex;align-items:baseline;gap:5px;margin-top:auto;padding-top:4px}
.slo-widget-value{font-size:1.6rem;font-weight:700;line-height:1}
.widget-alerted .slo-widget-value{color:#e53935}
.widget-ok .slo-widget-value{color:#43a047}
.slo-widget-label{font-size:.6rem;color:#999;line-height:1}
</style>
{{range .}}
<div style="margin-bottom:24px">
  <div class="slo-widget-service">{{.Title}}</div>
  <div class="slo-grid">
  {{range .Widgets}}
  <div class="slo-widget {{.StateClass}}">
    <div class="slo-widget-name">{{.Name}}</div>
    {{if .Definition}}<div class="slo-widget-def">{{.Definition}}</div>{{end}}
    <div class="slo-widget-count">
      <span class="slo-widget-value">{{.Value}}</span>
      <span class="slo-widget-label">{{.Label}}</span>
    </div>
  </div>
  {{end}}
  </div>
</div>
{{end}}
