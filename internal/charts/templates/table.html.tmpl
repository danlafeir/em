<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{.Title}}</title>
<style>
  body { margin: 0; padding: 20px; background: #fff; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  .container { max-width: 1200px; margin: 0 auto; }
  h1 { font-size: 1.5rem; margin-bottom: 1rem; }
  table { width: 100%; border-collapse: collapse; font-size: 14px; }
  thead th { background: #667ee2; color: #fff; padding: 10px 12px; text-align: left; font-weight: 600; }
  tbody td { padding: 8px 12px; border-bottom: 1px solid #eee; }
  tbody tr:nth-child(even) { background: #f5f5f5; }
  .outlier { color: #e53e3e; }
</style>
</head>
<body>
<div class="container">
  <h1>{{.Title}}</h1>
  <table>
    <thead>
      <tr>
        {{range .Headers}}<th>{{.}}</th>{{end}}
      </tr>
    </thead>
    <tbody>
      {{range .Rows}}<tr{{if .Outlier}} class="outlier"{{end}}>
        {{range .Cells}}<td>{{.}}</td>{{end}}
      </tr>{{end}}
    </tbody>
  </table>
</div>
</body>
</html>
