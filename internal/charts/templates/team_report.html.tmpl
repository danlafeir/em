<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{.Title}}</title>
<style>
body{margin:0;padding:16px;background:#fff;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif}
h2{margin:0 0 12px;font-size:.8rem;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.08em}
.section{max-width:1400px;margin:0 auto}
.jira-grid{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:20px}
hr.divider{border:none;border-top:2px solid #eee;margin:32px 0}
</style>
</head>
<body>
<div class="section">
  <h2>GitHub</h2>
  {{if .DeploymentHTML}}{{.DeploymentHTML}}{{else}}<p style="color:#bbb;font-size:.85rem;margin:0">No deployment data configured.</p>{{end}}
  <hr class="divider">
  <h2>JIRA Metrics</h2>
  {{.SummaryHTML}}
  <div class="jira-grid">
    {{.CycleTimeHTML}}
    {{.ThroughputHTML}}
    {{.LongestCTHTML}}
    {{.ForecastHTML}}
  </div>
</div>
</body>
</html>
