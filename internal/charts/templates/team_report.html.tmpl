<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{.Title}}</title>
<style>
body{margin:0;padding:16px;background:#fff;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif}
h2{margin:0 0 12px;font-size:.8rem;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.08em}
.section{max-width:1400px;margin:0 auto}
.jira-grid{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:20px}
hr.divider{border:none;border-top:2px solid #eee;margin:32px 0}
</style>
</head>
<body>
<div class="section">
  <div style="margin-bottom:24px;padding-bottom:16px;border-bottom:2px solid #eee;">
    <div style="font-size:1.4rem;font-weight:700;color:#111;letter-spacing:-.01em;">{{.Title}}</div>
  </div>
  {{if .ExecHealthcheckHTML}}
  {{.ExecHealthcheckHTML}}
  <hr class="divider">
  {{end}}
  {{if .SummaryHTML}}
  <h2>JIRA Metrics</h2>
  {{.SummaryHTML}}
  <div class="jira-grid">
    {{.ForecastHTML}}
    {{.ThroughputHTML}}
    {{.LongestCTHTML}}
    {{.CycleTimeHTML}}
  </div>
  {{end}}
  {{if .DeploymentHTML}}
  {{if .SummaryHTML}}<hr class="divider">{{end}}
  <h2>GitHub</h2>
  {{.DeploymentHTML}}
  {{end}}
  {{if .SnykChartHTML}}
  {{if or .SummaryHTML .DeploymentHTML}}<hr class="divider">{{end}}
  <h2>Snyk</h2>
  {{.SnykSummaryHTML}}
  {{.SnykChartHTML}}
  {{end}}
  {{if .DatadogHTML}}
  <hr class="divider">
  <h2>Datadog</h2>
  {{.DatadogHTML}}
  {{end}}
</div>
</body>
</html>
