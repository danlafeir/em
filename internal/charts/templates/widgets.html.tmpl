<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{.Title}}</title>
<style>
*{box-sizing:border-box}
body{margin:0;padding:24px;background:#f5f5f5;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif}
.page-header{max-width:1400px;margin:0 auto 20px}
.page-title{font-size:1.1rem;font-weight:600;color:#1a1a1a}
.page-sub{font-size:.8rem;color:#888;margin-top:4px}
.section{max-width:1400px;margin:0 auto 32px}
.section-title{font-size:.85rem;font-weight:600;color:#444;margin-bottom:12px;padding-bottom:6px;border-bottom:1px solid #ddd}
.widget-grid{display:flex;flex-wrap:wrap;gap:10px}
.widget{width:221px;height:105px;background:#fff;border-radius:10px;padding:10px 12px;display:flex;flex-direction:column;box-shadow:0 1px 3px rgba(0,0,0,.08)}
.widget-alerted{border-top:3px solid #e53935}
.widget-ok{border-top:3px solid #43a047}
.widget-name{font-size:.68rem;font-weight:600;color:#555;line-height:1.3;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}
.widget-definition{font-size:.6rem;color:#888;line-height:1.3;margin-top:2px}
.widget-count{display:flex;align-items:baseline;gap:5px;margin-top:auto;padding-top:4px}
.widget-value{font-size:1.6rem;font-weight:700;line-height:1}
.widget-alerted .widget-value{color:#e53935}
.widget-ok .widget-value{color:#43a047}
.widget-label{font-size:.6rem;color:#999;line-height:1}
</style>
</head>
<body>
<div class="page-header">
  <div class="page-title">{{.Title}}</div>
  {{if .Subtitle}}<div class="page-sub">{{.Subtitle}}</div>{{end}}
</div>
{{if .Sections}}
{{range .Sections}}
<div class="section">
  <div class="section-title">{{.Title}}</div>
  <div class="widget-grid">
  {{range .Widgets}}
  <div class="widget {{.StateClass}}">
    <div class="widget-name">{{.Name}}</div>
    {{if .Definition}}<div class="widget-definition">{{.Definition}}</div>{{end}}
    <div class="widget-count">
      <span class="widget-value">{{.Value}}</span>
      <span class="widget-label">{{.Label}}</span>
    </div>
  </div>
  {{end}}
  </div>
</div>
{{end}}
{{else}}
<div class="section">
  <div class="widget-grid">
  {{range .Widgets}}
  <div class="widget {{.StateClass}}">
    <div class="widget-name">{{.Name}}</div>
    {{if .Definition}}<div class="widget-definition">{{.Definition}}</div>{{end}}
    <div class="widget-count">
      <span class="widget-value">{{.Value}}</span>
      <span class="widget-label">{{.Label}}</span>
    </div>
  </div>
  {{end}}
  </div>
</div>
{{end}}
</body>
</html>
