<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{.Title}}</title>
<style>
*{box-sizing:border-box}
body{margin:0;padding:24px;background:#f5f5f5;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif}
.page-header{max-width:1400px;margin:0 auto 20px}
.page-title{font-size:1.1rem;font-weight:600;color:#1a1a1a}
.page-sub{font-size:.8rem;color:#888;margin-top:4px}
.widget-grid{max-width:1400px;margin:0 auto;display:flex;flex-wrap:wrap;gap:16px}
.widget{width:180px;height:180px;background:#fff;border-radius:12px;padding:16px;display:flex;flex-direction:column;justify-content:space-between;box-shadow:0 1px 4px rgba(0,0,0,.08)}
.widget-alerted{border-top:4px solid #e53935}
.widget-ok{border-top:4px solid #43a047}
.widget-name{font-size:.7rem;font-weight:600;color:#555;line-height:1.35;overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical}
.widget-value{font-size:2.4rem;font-weight:700;line-height:1;margin:auto 0}
.widget-alerted .widget-value{color:#e53935}
.widget-ok .widget-value{color:#43a047}
.widget-label{font-size:.65rem;color:#999;line-height:1.3}
</style>
</head>
<body>
<div class="page-header">
  <div class="page-title">{{.Title}}</div>
  {{if .Subtitle}}<div class="page-sub">{{.Subtitle}}</div>{{end}}
</div>
<div class="widget-grid">
{{range .Widgets}}
<div class="widget {{.StateClass}}">
  <div class="widget-name">{{.Name}}</div>
  <div class="widget-value">{{.Value}}</div>
  <div class="widget-label">{{.Label}}</div>
</div>
{{end}}
</div>
</body>
</html>
