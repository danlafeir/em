<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JIRA Metrics Report</title>
<style>
  body { margin: 0; padding: 20px; background: #fff; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; max-width: 1400px; margin: 0 auto; }
  .panel { border: 1px solid #e0e0e0; border-radius: 8px; padding: 16px; }
  .panel h2 { font-size: 1.1rem; margin: 0 0 12px 0; }
  canvas { width: 100% !important; height: 300px !important; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  thead th { background: #667ee2; color: #fff; padding: 8px 10px; text-align: left; font-weight: 600; }
  tbody td { padding: 6px 10px; border-bottom: 1px solid #eee; }
  tbody tr:nth-child(even) { background: #f5f5f5; }
  .outlier { color: #e53e3e; }
  .progress-wrap { display: flex; align-items: center; gap: 6px; }
  .progress-wrap progress { width: 70px; height: 7px; accent-color: #667ee2; }
  .progress-label { color: #888; font-size: 11px; white-space: nowrap; }
  .key { white-space: nowrap; }
  .ct-table td:nth-child(2), .ct-table th:nth-child(2) { white-space: nowrap; }
  .summary { max-width: 220px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .chart-panel { display: flex; flex-direction: column; justify-content: center; }
  .date-col { white-space: nowrap; }
</style>
</head>
<body>
<div class="grid">
  <div class="panel chart-panel">
    <canvas id="cycleTimeChart"></canvas>
  </div>
  <div class="panel chart-panel">
    <canvas id="throughputChart"></canvas>
  </div>
  <div class="panel">
    <h2>{{.LongestCTTitle}}</h2>
    <table class="ct-table">
      <thead>
        <tr>{{range .LongestCTHeaders}}<th>{{.}}</th>{{end}}</tr>
      </thead>
      <tbody>
        {{range .LongestCTRows}}<tr{{if .Outlier}} class="outlier"{{end}}>
          {{range .Cells}}<td>{{.}}</td>{{end}}
        </tr>{{end}}
      </tbody>
    </table>
  </div>
  <div class="panel">
    <h2>Epic Forecast</h2>
    <table>
      <thead>
        <tr><th class="key">Epic</th><th class="summary">Summary</th><th>Progress</th><th class="date-col">50%</th><th class="date-col">85%</th><th class="date-col">95%</th></tr>
      </thead>
      <tbody>
        {{range .ForecastRows}}<tr>
          <td class="key">{{.EpicKey}}</td>
          <td class="summary">{{.Summary}}</td>
          <td>
            <div class="progress-wrap">
              <progress value="{{.ProgressVal}}" max="{{.ProgressMax}}"></progress>
              <span class="progress-label">{{.ProgressLabel}}</span>
            </div>
          </td>
          <td class="date-col">{{.Forecast50}}</td>
          <td class="date-col">{{.Forecast85}}</td>
          <td class="date-col">{{.Forecast95}}</td>
        </tr>{{end}}
      </tbody>
    </table>
  </div>
</div>
<script>{{.ChartJS}}</script>
<script>{{.DateAdapterJS}}</script>
<script>
  new Chart(document.getElementById('cycleTimeChart').getContext('2d'), {{.CycleTimeConfigJSON}});
  new Chart(document.getElementById('throughputChart').getContext('2d'), {{.ThroughputConfigJSON}});
</script>
</body>
</html>
