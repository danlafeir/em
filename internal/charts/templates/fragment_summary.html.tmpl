<div style="border:1px solid #e0e0e0;border-radius:8px;padding:16px 20px;margin-bottom:20px;">
  <div style="font-size:.7rem;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px;">Summary</div>
  <div style="display:flex;gap:32px;flex-wrap:wrap;">
    <div>
      <div style="font-size:1.6rem;font-weight:600;color:#1a1a1a;line-height:1;">{{.AvgCycleTime}}</div>
      <div style="font-size:.75rem;color:#888;margin-top:3px;">Avg Cycle Time</div>
    </div>
    <div style="width:1px;background:#e0e0e0;align-self:stretch;"></div>
    <div>
      <div style="font-size:1.6rem;font-weight:600;color:#1a1a1a;line-height:1;">{{.AvgThroughput}}</div>
      <div style="font-size:.75rem;color:#888;margin-top:3px;">Avg Throughput / Week</div>
    </div>
    <div style="width:1px;background:#e0e0e0;align-self:stretch;"></div>
    <div>
      <div style="font-size:1.6rem;font-weight:600;color:#1a1a1a;line-height:1;">{{.ActiveEpics}}</div>
      <div style="font-size:.75rem;color:#888;margin-top:3px;">Epics With Active Work</div>
    </div>
  </div>
</div>
