<div style="margin-bottom:28px;">
  <div style="font-size:.7rem;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px;">Executive Healthcheck</div>
  <div style="display:flex;gap:12px;flex-wrap:wrap;">

    <div style="flex:1;min-width:110px;border:1px solid #e0e0e0;border-radius:8px;padding:14px 18px;">
      <div style="font-size:.65rem;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px;">Avg Cycle Time</div>
      <div style="font-size:1.5rem;font-weight:700;color:#111;line-height:1;">{{if .HasJIRAData}}{{.AvgCycleTime}}{{else}}—{{end}}</div>
    </div>

    <div style="flex:1;min-width:110px;border:1px solid #e0e0e0;border-radius:8px;padding:14px 18px;">
      <div style="font-size:.65rem;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px;">Throughput / Week</div>
      <div style="font-size:1.5rem;font-weight:700;color:#111;line-height:1;">{{if .HasJIRAData}}{{.AvgThroughput}}{{else}}—{{end}}</div>
    </div>

    <div style="flex:1;min-width:110px;border:1px solid #e0e0e0;border-radius:8px;padding:14px 18px;">
      <div style="font-size:.65rem;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px;">Epics With Active Work</div>
      <div style="font-size:1.5rem;font-weight:700;color:#111;line-height:1;">{{if .HasJIRAData}}{{.ActiveEpics}}{{else}}—{{end}}</div>
    </div>

    {{if not .HideDeployFreq}}
    <div style="flex:1;min-width:110px;border:1px solid #e0e0e0;border-radius:8px;padding:14px 18px;">
      <div style="font-size:.65rem;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px;">Deploy Frequency</div>
      <div style="font-size:1.5rem;font-weight:700;color:#111;line-height:1;">{{if .HasDeployData}}{{.AvgDeployFreq}}{{else}}—{{end}}</div>
      <div style="font-size:.7rem;color:#888;margin-top:4px;">{{if .HasDeployData}}{{.LastWeekDeploys}} last week{{else}}—{{end}}</div>
    </div>
    {{end}}

    <div style="flex:1;min-width:160px;border:1px solid #e0e0e0;border-radius:8px;padding:14px 18px;">
      <div style="font-size:.65rem;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px;">Snyk Vulnerabilities</div>
      {{if .HasSnykData}}
      <div style="display:flex;gap:16px;align-items:flex-end;">
        <div>
          <div style="font-size:1.5rem;font-weight:700;line-height:1;{{if gt .Exploitable 0}}color:#dc2626;{{else}}color:#111;{{end}}">{{.Exploitable}}</div>
          <div style="font-size:.65rem;color:#888;margin-top:4px;">Exploitable</div>
        </div>
        <div>
          <div style="font-size:1.5rem;font-weight:700;line-height:1;{{if gt .Critical 0}}color:#dc2626;{{else}}color:#111;{{end}}">{{.Critical}}</div>
          <div style="font-size:.65rem;color:#888;margin-top:4px;">Critical</div>
        </div>
        <div>
          <div style="font-size:1.5rem;font-weight:700;line-height:1;{{if gt .High 0}}color:#ea580c;{{else}}color:#111;{{end}}">{{.High}}</div>
          <div style="font-size:.65rem;color:#888;margin-top:4px;">High</div>
        </div>
      </div>
      {{else}}
      <div style="font-size:1.5rem;font-weight:700;color:#111;line-height:1;">—</div>
      {{end}}
    </div>

  </div>
</div>
